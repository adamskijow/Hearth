{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping Hearth's /metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Runner health",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "hearth_healthy", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Down", "index": 0 }, "1": { "text": "Healthy", "index": 1 } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ] }, "colorMode": "background", "graphMode": "none", "textMode": "value", "justifyMode": "auto" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Phase",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "hearth_phase == 1", "legendFormat": "{{phase}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ] }, "colorMode": "none", "graphMode": "none", "textMode": "name", "justifyMode": "auto" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Healthy uptime",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "hearth_uptime_seconds", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ] }, "colorMode": "none", "graphMode": "area", "textMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Restarts (session)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "hearth_restarts_total", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ] }, "colorMode": "none", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "System memory used (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "hearth_memory_used_percent", "legendFormat": "memory %", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 90 } ] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Runner resident memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "hearth_runner_resident_bytes", "legendFormat": "runner RSS", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Consecutive failed probes",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "hearth_consecutive_failures", "legendFormat": "failures", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 40 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Thermal state",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "hearth_thermal == 1", "legendFormat": "{{state}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ] }, "colorMode": "none", "graphMode": "none", "textMode": "name" }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Resident models",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "hearth_resident_models", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ] }, "colorMode": "none", "graphMode": "none", "textMode": "value" }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [ "hearth", "ollama" ],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "title": "Hearth: local LLM runner",
  "uid": "hearth-runner",
  "version": 1
}
